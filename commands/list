#!/usr/bin/env bash
# 列出目标 Server 上的所有 Clip Instance
# stdin: {"server": "server-name"} 或空（列出所有 Server 的 Clip）
# stdout: JSON — 整合后的 Clip 列表

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
SERVERS_FILE="${SCRIPT_DIR}/../data/servers.json"

if [ ! -f "$SERVERS_FILE" ]; then
  echo '{"error": "no servers configured, use add-server first"}' >&2
  exit 1
fi

# 读 stdin（可能为空）
INPUT=$(cat 2>/dev/null || echo '{}')
if [ -z "$INPUT" ]; then
  INPUT='{}'
fi

TARGET_SERVER=$(echo "$INPUT" | jq -r '.server // empty')

# 获取要查询的 server 列表
if [ -n "$TARGET_SERVER" ]; then
  SERVERS=$(jq -c --arg name "$TARGET_SERVER" '[.servers[] | select(.name == $name)]' "$SERVERS_FILE")
  COUNT=$(echo "$SERVERS" | jq 'length')
  if [ "$COUNT" -eq 0 ]; then
    echo "{\"error\": \"server '${TARGET_SERVER}' not found\"}" >&2
    exit 1
  fi
else
  SERVERS=$(jq -c '.servers' "$SERVERS_FILE")
fi

# 遍历每个 server，调用 ListClips
RESULTS='[]'
ERRORS='[]'

for SERVER in $(echo "$SERVERS" | jq -c '.[]'); do
  NAME=$(echo "$SERVER" | jq -r '.name')
  HOST=$(echo "$SERVER" | jq -r '.host')
  PORT=$(echo "$SERVER" | jq -r '.port')
  TOKEN=$(echo "$SERVER" | jq -r '.token')

  URL="http://${HOST}:${PORT}/pinix.v1.AdminService/ListClips"

  RESPONSE=$(curl -s --connect-timeout 5 --max-time 10 \
    -X POST "$URL" \
    -H "Content-Type: application/json" \
    -H "Authorization: Bearer ${TOKEN}" \
    -d '{}' 2>&1) || true

  # 检查是否成功获取到 clips
  CLIPS=$(echo "$RESPONSE" | jq -c '.clips // empty' 2>/dev/null)

  if [ -n "$CLIPS" ] && [ "$CLIPS" != "null" ]; then
    # 给每个 clip 附加 server 来源信息
    TAGGED=$(echo "$CLIPS" | jq -c --arg server "$NAME" --arg host "$HOST" --argjson port "$PORT" \
      '[.[] | . + {server: $server, serverHost: $host, serverPort: $port}]')
    RESULTS=$(echo "$RESULTS" "$TAGGED" | jq -s '.[0] + .[1]')
  else
    ERROR_MSG=$(echo "$RESPONSE" | jq -r '.message // .error // "connection failed"' 2>/dev/null || echo "connection failed")
    ERRORS=$(echo "$ERRORS" | jq -c --arg server "$NAME" --arg error "$ERROR_MSG" \
      '. + [{server: $server, error: $error}]')
  fi
done

# 输出结果
jq -n --argjson clips "$RESULTS" --argjson errors "$ERRORS" \
  '{clips: $clips, errors: $errors}'
