#!/usr/bin/env bash
# 移除一个 Server 连接配置
# stdin: {"name": "home"}

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
SERVERS_FILE="${SCRIPT_DIR}/../data/servers.json"

INPUT=$(cat)
NAME=$(echo "$INPUT" | jq -r '.name // empty')

if [ -z "$NAME" ]; then
  echo '{"error": "missing required field: name"}' >&2
  exit 1
fi

if [ ! -f "$SERVERS_FILE" ]; then
  echo '{"error": "no servers configured"}' >&2
  exit 1
fi

# 检查是否存在
EXISTING=$(jq -r --arg name "$NAME" '.[] | select(.name == $name) | .name' "$SERVERS_FILE")
if [ -z "$EXISTING" ]; then
  echo "{\"error\": \"server '${NAME}' not found\"}" >&2
  exit 1
fi

# 移除
jq --arg name "$NAME" '[.[] | select(.name != $name)]' \
  "$SERVERS_FILE" > "${SERVERS_FILE}.tmp" && mv "${SERVERS_FILE}.tmp" "$SERVERS_FILE"

echo "{\"ok\": true, \"message\": \"server '${NAME}' removed\"}"
